# Database (Postgres — use Neon/Vercel Postgres in production; local Docker or Neon dev branch for dev)
# On Vercel with the Postgres/Neon integration, POSTGRES_PRISMA_URL is auto-mapped at build time.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_DIAGNOSTIC=price_...

# App URL (used for Stripe redirect URLs and report links in email)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public contact for privacy/terms pages (optional; falls back to EMAIL_FROM address)
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com

# Signs preview/report access tokens (required in production)
DIAGNOSTIC_ACCESS_SECRET=change-me-to-a-long-random-string

# Email via Resend
# On Vercel: install Resend from Marketplace — it auto-adds RESEND_API_KEY
# You still need to set EMAIL_FROM manually (see README)
RESEND_API_KEY=re_...
EMAIL_FROM="Revenue Leak <onboarding@resend.dev>"

# Cron (Vercel) — nurture email for unpaid previews after NURTURE_DELAY_HOURS
CRON_SECRET=generate-a-long-random-string
NURTURE_DELAY_HOURS=24
NURTURE_CHECKOUT_ABANDON_DELAY_HOURS=2
NURTURE_BATCH_LIMIT=50

# Analytics (optional — omit to disable all tracking scripts)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Ads purchase conversion (optional): AW-CONVERSION_ID/CONVERSION_LABEL
NEXT_PUBLIC_GOOGLE_ADS_SEND_TO=AW-XXXXXXXXXX/YYYYYYYYYY
# Meta Pixel (optional — for Meta/Facebook ads)
NEXT_PUBLIC_META_PIXEL_ID=1234567890123456

# IndexNow (Bing URL submission) — key file must exist at public/{key}.txt
INDEXNOW_KEY=your-32-char-hex-key
# Set to false to hide the Product Hunt footer badge after launch week
# NEXT_PUBLIC_PRODUCT_HUNT_ENABLED=false
